{{ ansible_managed | comment }}

services:
  homeassistant:
    container_name: homeassistant
    image: "ghcr.io/home-assistant/home-assistant:stable"
    volumes:
      - /compose/homeassistant/bind/config:/config
      - /etc/localtime:/etc/localtime:ro
      - /run/dbus:/run/dbus:ro # will see when necessary
    restart: unless-stopped
    network_mode: host
    privileged: true # will see when necessary
